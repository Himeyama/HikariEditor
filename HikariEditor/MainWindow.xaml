<Window
    x:Class="HikariEditor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HikariEditor"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>
    
    <Grid
        RowDefinitions="40, *, 24" x:Name="Window">
        <Grid Grid.Row="0">
            <Grid ColumnDefinitions="Auto, Auto, *">
                <StackPanel Padding="16, 0, 0, 0" Grid.Column="0" Orientation="Horizontal" Width="114">
                    <TextBlock Padding="0, 0, 0, 0" Text="Auto Save" x:Uid="AutoSave" VerticalAlignment="Center" FontSize="12" />
                    <Grid Padding="8, 1, 0, 0">
                        <ToggleSwitch AutomationProperties.Name="AutoSaveToggleSwitch"
                              OffContent="" OnContent=""
                              IsOn="{x:Bind AutoSave.IsChecked, Mode=TwoWay}"
                              Toggled="ToggleSwitch_Toggled"
                              x:Name="AutoSaveToggleSwitch" />
                        <!-- オン/オフ表示はマージンが元フォントの字形に合わせ調整済みのため既定フォントに戻す -->
                        <TextBlock FontSize="10" x:Name="AutoSaveToggleSwitchText" IsHitTestVisible="False" FontFamily="XamlAutoFontFamily" />
                    </Grid>
                </StackPanel>
                
                <!-- メニュー項目の既定スタイルは FontFamily を継承既定のままにするため、
                     ここで明示指定して配下の項目まで Noto Sans JP を伝播させる -->
                <MenuBar Grid.Column="1" FontFamily="{StaticResource ContentControlThemeFontFamily}">
                    <MenuBarItem Title="File" x:Uid="File">
                        <MenuFlyoutItem Text="Open Directory..." x:Uid="Open" x:Name="Open" Click="OpenClick" FontFamily="{StaticResource ContentControlThemeFontFamily}">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="O"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:FieldModifier="Public" Text="Open Explorer" x:Name="OpenExplorer" x:Uid="OpenExplorer" Click="ClickOpenExplorer" FontFamily="{StaticResource ContentControlThemeFontFamily}"/>
                        <MenuFlyoutSeparator />
                        <ToggleMenuFlyoutItem Text="Auto Save" x:Uid="AutoSave" x:Name="AutoSave" x:FieldModifier="Public" FontFamily="{StaticResource ContentControlThemeFontFamily}" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Exit" x:Uid="Exit" Click="ExitClick" FontFamily="{StaticResource ContentControlThemeFontFamily}"/>
                    </MenuBarItem>

                    <MenuBarItem Title="Edit" x:Uid="Edit">
                        <MenuFlyoutItem x:Uid="Copy" Text="Copy" Click="ClickCopyText" FontFamily="{StaticResource ContentControlThemeFontFamily}">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="C"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Uid="Paste" Text="Paste" Click="ClickPasteText" FontFamily="{StaticResource ContentControlThemeFontFamily}">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="V"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                    </MenuBarItem>

                    <MenuBarItem Title="Terminal" x:Uid="Terminal">
                        <MenuFlyoutItem Name="OpenTerminal"  x:FieldModifier="Public" x:Uid="OpenTerminal" Text="Open Terminal" Click="ClickOpenTerminal" FontFamily="{StaticResource ContentControlThemeFontFamily}">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="T"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Name="OpenLog"  x:FieldModifier="Public" x:Uid="OpenLog" Text="Open Log" Click="ClickOpenLog" FontFamily="{StaticResource ContentControlThemeFontFamily}">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="U"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                    </MenuBarItem>

                    <MenuBarItem Title="View" x:Uid="View">
                        <ToggleMenuFlyoutItem Text="AI Agent" x:Uid="ToggleAI" x:Name="ToggleAI" Click="ClickToggleAI" FontFamily="{StaticResource ContentControlThemeFontFamily}">
                            <ToggleMenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="I"/>
                            </ToggleMenuFlyoutItem.KeyboardAccelerators>
                        </ToggleMenuFlyoutItem>
                    </MenuBarItem>

                    <MenuBarItem Title="Help" x:Uid="Help">
                        <MenuFlyoutItem Text="About Hikari Editor" Click="ClickAboutDialog" x:Uid="About" FontFamily="{StaticResource ContentControlThemeFontFamily}"/>
                    </MenuBarItem>
                </MenuBar>

                <Grid x:Name="AppTitleBar" Grid.Column="2" x:FieldModifier="Public" >
                    <!-- <TextBlock x:Name="AppTitleTextBlock" 
                        x:Uid="AppTitleText"
                        Text="Editor"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center" /> -->
                </Grid>
            </Grid>
        </Grid>
        <Grid Grid.Row="1" x:Name="SideMenuEditorArea" x:FieldModifier="Public" ColumnDefinitions="48, Auto, *, Auto, 0">
            <NavigationView 
                Grid.Column="0"
                ItemInvoked="MenuChanged"
                x:Name="Menu" PaneDisplayMode="LeftCompact"
                IsBackButtonVisible="Collapsed" IsBackEnabled="False"
                IsPaneToggleButtonVisible="False"
                IsSettingsVisible="False"
                x:FieldModifier="Public">
                <NavigationView.MenuItems>
                    <NavigationViewItem Tag="Explorer" x:FieldModifier="Public" x:Name="ItemExplorer">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xF56E;" FontFamily="Segoe Fluent Icons"></FontIcon>
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                    <!-- AI はパネルのトグル（ただのボタン）。選択＝アクティブ表示は動かさない -->
                    <NavigationViewItem Tag="AI" x:FieldModifier="Public" x:Name="ItemAI" SelectsOnInvoked="False">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE8BD;" FontFamily="Segoe Fluent Icons"></FontIcon>
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                </NavigationView.MenuItems>
                <Frame x:Name="contentFrame" x:FieldModifier="Public" />
            </NavigationView>
            <!-- エクスプローラーの横幅を左右にドラッグしてリサイズするハンドル -->
            <local:ResizeHandle Grid.Column="1" x:Name="explorerSplitter" Width="6"
                                Orientation="Vertical" Visibility="Collapsed"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                PointerPressed="ExplorerSplitter_PointerPressed"
                                PointerMoved="ExplorerSplitter_PointerMoved"
                                PointerReleased="ExplorerSplitter_PointerReleased"
                                PointerCaptureLost="ExplorerSplitter_PointerReleased">
                <!-- Transparent な当たり判定を確保しつつ左端に区切り線を描く -->
                <Border Background="Transparent" BorderThickness="1,0,0,0"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" />
            </local:ResizeHandle>
            <Grid Grid.Column="2" RowDefinitions="*, Auto, Auto" x:FieldModifier="Public" x:Name="RightSideFrames">
                <Grid ColumnDefinitions="*, 0" x:FieldModifier="Public" Grid.Row="0" x:Name="rightArea">
                    <Frame Grid.Column="0" x:Name="editorFrame" x:FieldModifier="Public" Height="0" />
                    <Frame Grid.Column="1" x:Name="previewFrame" x:FieldModifier="Public" Background="White" />
                </Grid>
                <!-- ターミナル／ログ領域を上下にドラッグしてリサイズするハンドル -->
                <local:ResizeHandle Grid.Row="1" x:Name="terminalSplitter" Height="6"
                                    Visibility="Collapsed"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch"
                                    PointerPressed="TerminalSplitter_PointerPressed"
                                    PointerMoved="TerminalSplitter_PointerMoved"
                                    PointerReleased="TerminalSplitter_PointerReleased"
                                    PointerCaptureLost="TerminalSplitter_PointerReleased">
                    <!-- Transparent な当たり判定を確保しつつ上端に区切り線を描く -->
                    <Border Background="Transparent" BorderThickness="0,1,0,0"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" />
                </local:ResizeHandle>
                <Frame Grid.Row="2" x:Name="terminalFrame" x:FieldModifier="Public" Height="0" />
            </Grid>
            <!-- AI パネルを左右にドラッグしてリサイズするハンドル -->
            <local:ResizeHandle Grid.Column="3" x:Name="aiSplitter" Width="6"
                                Orientation="Vertical" Visibility="Collapsed"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                PointerPressed="AISplitter_PointerPressed"
                                PointerMoved="AISplitter_PointerMoved"
                                PointerReleased="AISplitter_PointerReleased"
                                PointerCaptureLost="AISplitter_PointerReleased">
                <!-- Transparent な当たり判定を確保しつつ左端に区切り線を描く -->
                <Border Background="Transparent" BorderThickness="1,0,0,0"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" />
            </local:ResizeHandle>
            <local:AIPanel Grid.Column="4" x:Name="aiPanel" />
        </Grid>
        <Grid Grid.Row="2">
            <Grid ColumnDefinitions="Auto, *, Auto, Auto">
                <Grid.Resources>
                    <!-- ステータスバーのボタンは枠線を常に透明にし、背景はホバー・押下時だけうっすら変化させる -->
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#22808080" />
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#33808080" />
                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                </Grid.Resources>
                <!-- git リポジトリのときだけ表示。クリックでブランチ切り替えモーダルを開く -->
                <Button Grid.Column="0" Content="" x:Name="BranchBtn" Click="ClickBranchBtn" FontSize="12" Padding="6, 2, 6, 2" Margin="4, 0, 0, 0" Visibility="Collapsed" x:FieldModifier="Public" Background="Transparent" BorderBrush="Transparent" />
                <TextBlock Grid.Column="1" Text="" x:Name="StatusBar" Margin="8, 0, 0, 0" x:FieldModifier="Public" FontSize="12" VerticalAlignment="Center" />
                <!-- AI パネル表示中だけ表示。クリックでモデル設定モーダルを開く。LF/CRLF ボタンと同スタイル。 -->
                <Button Grid.Column="2" Content="LLM が未登録" x:Name="ModelBtn" Click="ClickModelBtn" FontSize="12" Padding="6, 2, 6, 2" Margin="0, 0, 0, 0" Visibility="Collapsed" x:FieldModifier="Public" Background="Transparent" BorderBrush="Transparent" />
                <Button Grid.Column="3" Content="LF" x:Name="NLBtn" Click="ClickNLBtn" FontSize="12" Padding="6, 2, 6, 2" Margin="8, 0, 8, 0" Width="56" x:FieldModifier="Public" Background="Transparent" BorderBrush="Transparent" />
            </Grid>
        </Grid>
    </Grid>
</Window>
